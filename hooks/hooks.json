{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-task-guard.js\" \"$CLAUDE_TOOL_INPUT_SUBAGENT_TYPE\"",
            "blocking": true,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-agent-reads.js\"",
            "blocking": false,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-main-thread-mutations.js\"",
            "blocking": true,
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-orchestrator-source-writes.js\"",
            "blocking": true,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-orchestrator-step0.js\"",
            "blocking": true,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-main-thread-skills.js\"",
            "blocking": true,
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/block-aiaw-task-in-plan-mode.js\"",
            "blocking": true,
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-chief-orchestrator-stop.js\"",
            "blocking": true,
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-artifact-chain.js\" \"$CLAUDE_TOOL_INPUT_FILE_PATH\"",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-summary-telemetry.js\" \"$CLAUDE_TOOL_INPUT_FILE_PATH\"",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-orchestration-state-write.js\" \"$CLAUDE_TOOL_INPUT_FILE_PATH\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
